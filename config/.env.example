# GNC Collaboration Hub environment template
# Copy this file to .env only on the machine or server that runs the hub.
# Never commit .env, API keys, wallet private keys, prompts, results, or user context.
# All real values below must stay server-side/off-chain.

# Gemini structure layer
# Required for dry/live Gemini calls. Leave blank for local-only proof mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Manus execution layer
# Required only when creating real Manus tasks.
MANUS_API_KEY=
MANUS_API_BASE=https://api.manus.ai
MANUS_AGENT_TYPE=manus_1.6_lite

# Meli orchestration/review layer
# Leave MELI_API_URL blank if Meli is not exposed as an API yet; the hub will still include Meli as a local review gate.
MELI_NAME=Meli
MELI_ROLE=review gate, continuity layer, and intent/context checker
MELI_INSTRUCTIONS=Review Gemini's structured brief against the user's actual context, goals, tone, constraints, and recent history. Decide whether Manus should execute as-is, after revision, or not at all. Do not include secrets.
MELI_API_URL=
MELI_API_KEY=

# GNC receipt layer
# Required only for deployment and live on-chain receipt writes.
# GNC_PRIVATE_KEY must be a funded wallet private key kept only in server-side secrets.
GNC_RPC_URL=
GNC_CHAIN_ID=
GNC_PRIVATE_KEY=
TRIO_RECEIPT_CONTRACT_ADDRESS=

# Optional recovered GNC network identifiers; useful for operators, not required by the hub runner.
GNC_SUBNET_ID=
GNC_BLOCKCHAIN_ID=
GNC_VMID=

# Private off-chain shared-state store
# This JSONL file contains readable shared-state objects and must remain private.
TRIO_OFFCHAIN_LOG=./data/trio-hub-log.jsonl
